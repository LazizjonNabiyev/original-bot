// ─── ADMIN PANEL ──────────────────────────────────────────────
function isAdmin(uid) {
  return ADMIN_IDS.includes(Number(uid));
}

function sendAdminPanel(chatId) {
  const s = getStats();
  const text =
    `🔧 *Admin Panel — Original Supermarket*\n\n` +
    `👥 Foydalanuvchilar: *${s.users}*\n\n` +
    `📊 *Murojaatlar:*\n` +
    `📝 Shikoyat: *${s.complaint}*\n` +
    `📍 Lokatsiya: *${s.location}*\n` +
    `✍️ Murojaat: *${s.appeal}*\n` +
    `━━━━━━━━━━━━\n` +
    `📦 Jami: *${s.total}*`;

  const kb = { inline_keyboard: [
    [{ text: "📊 Google Sheets ko'rish", callback_data: "admin_sheet" }],
    [{ text: "🔄 Yangilash", callback_data: "admin_refresh" }],
  ]};
  sendMsg(chatId, text, kb);
}

// ─── KANALGA YUBORISH ─────────────────────────────────────────
function buildChannelText(state, user) {
  const labels = {
    uz: { complaint: "📝 SHIKOYAT", location: "📍 LOKATSIYA", appeal: "✍️ MUROJAAT" },
    ru: { complaint: "📝 ЖАЛОБА",   location: "📍 ЛОКАЦИЯ",   appeal: "✍️ ОБРАЩЕНИЕ" },
  };
  const lang  = state.lang || "uz";
  const label = labels[lang][state.type];
  const name  = [user.first_name, user.last_name].filter(Boolean).join(" ");
  const uname = user.username ? "@" + user.username : "—";
  const date  = Utilities.formatDate(new Date(), "Asia/Tashkent", "dd.MM.yyyy HH:mm");

  return (
    `${label}\n` +
    `━━━━━━━━━━━━━━\n` +
    `👤 *Ism:* ${name}\n` +
    `🔗 *Username:* ${uname}\n` +
    `🆔 *ID:* \`${user.id}\`\n` +
    `🌐 *Til:* ${lang === "uz" ? "O'zbek" : "Русский"}\n` +
    `━━━━━━━━━━━━━━\n` +
    `💬 ${state.text || "—"}\n` +
    `━━━━━━━━━━━━━━\n` +
    `🕐 ${date}\n\n` +
    `_Javob berish uchun foydalanuvchi ID: \`${user.id}\`_`
  );
}

function sendToChannel(state, user, photoId) {
  const text = buildChannelText(state, user);
  if (photoId) {
    sendPhotoMsg(CHANNEL_ID, photoId, text);
  } else {
    sendMsg(CHANNEL_ID, text);
  }
}

// ─── JAVOB BERISH (Admin reply) ───────────────────────────────
// Admin kanalda xabarga reply qilganda, bot foydalanuvchiga yuboradi
// Bu funksiya adminning /reply <user_id> <xabar> buyrug'ini ham qabul qiladi
function handleAdminReply(msg) {
  // Kanal postiga reply bo'lsa
  if (msg.reply_to_message && msg.reply_to_message.text) {
    const original = msg.reply_to_message.text;
    const match = original.match(/ID: `(\d+)`/);
    if (match) {
      const targetId = match[1];
      const adminName = msg.from.first_name || "Admin";
      const replyText = `📩 *Original Supermarket javobi:*\n\n${msg.text}\n\n_— ${adminName}_`;
      sendMsg(targetId, replyText);
      sendMsg(msg.chat.id, "✅ Javob yuborildi!");
      return true;
    }
  }
  // /reply <id> <xabar> buyrug'i
  const replyMatch = (msg.text || "").match(/^\/reply (\d+) (.+)/s);
  if (replyMatch) {
    const targetId = replyMatch[1];
    const replyText = `📩 *Original Supermarket javobi:*\n\n${replyMatch[2]}`;
    sendMsg(targetId, replyText);
    sendMsg(msg.chat.id, "✅ Javob yuborildi!");
    return true;
  }
  return false;
}

// ─── ASOSIY WEBHOOK ───────────────────────────────────────────
function doPost(e) {
  try {
    const update = JSON.parse(e.postData.contents);
    if (update.callback_query) handleCallback(update.callback_query);
    else if (update.message)   handleMessage(update.message);
  } catch(err) {
    Logger.log("Error: " + err);
  }
  return ContentService.createTextOutput("OK");
}

// ─── CALLBACK ────────────────────────────────────────────────
function handleCallback(cb) {
  answerCb(cb.id);
  const chatId = cb.message.chat.id;
  const uid    = cb.from.id;
  const data   = cb.data;
  const state  = getState(uid);

  if (data.startsWith("lang_")) {
    const lang = data.replace("lang_", "");
    saveUser(cb.from, lang);
    setState(uid, { step: "menu", lang, type: null, text: null });
    const name = cb.from.first_name || "Do'stim";
    sendMsg(chatId, T[lang].welcome.replace("{name}", name), kbMenu(lang));
    return;
  }

  if (data.startsWith("type_")) {
    const type = data.replace("type_", "");
    const lang = state.lang || "uz";
    setState(uid, { ...state, step: "get_text", type });
    const prompt = type === "location" ? T[lang].ask_location : T[lang].ask_text;
    sendMsg(chatId, prompt, kbBack(lang));
    return;
  }

  if (data === "back_menu") {
    const lang = state.lang || "uz";
    setState(uid, { step: "menu", lang, type: null, text: null });
    const name = cb.from.first_name || "Do'stim";
    sendMsg(chatId, T[lang].welcome.replace("{name}", name), kbMenu(lang));
    return;
  }

  if (data === "photo_yes") {
    const lang = state.lang || "uz";
    setState(uid, { ...state, step: "get_photo" });
    sendMsg(chatId, T[lang].ask_photo_now, kbSkip(lang));
    return;
  }

  if (data === "photo_no") {
    finish(chatId, uid, cb.from, state, null);
    return;
  }

  if (data === "photo_skip") {
    finish(chatId, uid, cb.from, state, null);
    return;
  }

  if (data === "admin_refresh") {
    sendAdminPanel(chatId);
    return;
  }

  if (data === "admin_sheet") {
    const url = SpreadsheetApp.getActiveSpreadsheet().getUrl();
    sendMsg(chatId, `📊 [Google Sheets ni ochish](${url})`);
    return;
  }
}

// ─── MESSAGE ─────────────────────────────────────────────────
function handleMessage(msg) {
  const chatId = msg.chat.id;
  const uid    = msg.from.id;
  const text   = msg.text || "";
  const state  = getState(uid);

  // /start
  if (text === "/start") {
    clearState(uid);
    sendMsg(chatId, "🌐 Tilni tanlang / Выберите язык:", kbLang());
    return;
  }

  // Admin buyruqlari
  if (isAdmin(uid)) {
    if (text === "/admin") {
      sendAdminPanel(chatId);
      return;
    }
    if (handleAdminReply(msg)) return;
  }

  const lang = state.lang || "uz";
  const step = state.step;

  // Matn yoki lokatsiya kiritish
  if (step === "get_text") {
    let content = text;
    if (msg.location) {
      content = `📍 Geo: ${msg.location.latitude}, ${msg.location.longitude}`;
    }
    if (!content) return;
    setState(uid, { ...state, step: "ask_photo", text: content });
    sendMsg(chatId, T[lang].ask_photo, kbPhoto(lang));
    return;
  }

  // Rasm kutilayotgan vaqt
  if (step === "get_photo") {
    if (msg.photo) {
      const fileId = msg.photo[msg.photo.length - 1].file_id;
      finish(chatId, uid, msg.from, state, fileId);
    } else {
      finish(chatId, uid, msg.from, state, null);
    }
    return;
  }

  // Boshqa holat — menyuga qaytarish
  if (step === "menu" || step === "start") {
    const name = msg.from.first_name || "Do'stim";
    sendMsg(chatId, T[lang].welcome.replace("{name}", name), kbMenu(lang));
  }
}

// ─── YAKUNLASH ────────────────────────────────────────────────
function finish(chatId, uid, user, state, photoId) {
  const lang = state.lang || "uz";
  sendMsg(chatId, T[lang].sending);
  sendToChannel(state, user, photoId);
  incrementStat(uid, state.type);
  clearState(uid);
  const name = user.first_name || "Do'stim";
  sendMsg(chatId, T[lang].success, kbMenu(lang));
}

