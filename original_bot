// ─── STATE (xotira) ──────────────────────────────────────────
function getState(uid) {
  const p = PropertiesService.getUserProperties();
  const r = p.getProperty("s_" + uid);
  return r ? JSON.parse(r) : { step: "start", lang: null, type: null, text: null };
}
function setState(uid, s) {
  PropertiesService.getUserProperties().setProperty("s_" + uid, JSON.stringify(s));
}
function clearState(uid) {
  PropertiesService.getUserProperties().deleteProperty("s_" + uid);
}

// ─── GOOGLE SHEETS ────────────────────────────────────────────
function getSheet() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  let sh = ss.getSheetByName(SHEET_NAME);
  if (!sh) {
    sh = ss.insertSheet(SHEET_NAME);
    sh.appendRow(["ID", "Ism", "Username", "Til", "Sana", "Shikoyat", "Lokatsiya", "Murojaat", "Jami"]);
    sh.setFrozenRows(1);
  }
  return sh;
}

function saveUser(user, lang) {
  const sh = getSheet();
  const data = sh.getDataRange().getValues();
  const uid = String(user.id);
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][0]) === uid) return; // allaqachon bor
  }
  const name = (user.first_name || "") + (user.last_name ? " " + user.last_name : "");
  const uname = user.username ? "@" + user.username : "—";
  const date = Utilities.formatDate(new Date(), "Asia/Tashkent", "dd.MM.yyyy HH:mm");
  sh.appendRow([uid, name, uname, lang.toUpperCase(), date, 0, 0, 0, 0]);
}

function incrementStat(uid, type) {
  const sh = getSheet();
  const data = sh.getDataRange().getValues();
  const colMap = { complaint: 5, location: 6, appeal: 7 };
  const col = colMap[type];
  for (let i = 1; i < data.length; i++) {
    if (String(data[i][0]) === String(uid)) {
      const row = i + 1;
      sh.getRange(row, col + 1).setValue((data[i][col] || 0) + 1);
      sh.getRange(row, 9).setValue((data[i][8] || 0) + 1); // jami
      return;
    }
  }
}

function getStats() {
  const sh = getSheet();
  const data = sh.getDataRange().getValues();
  if (data.length < 2) return { users: 0, complaint: 0, location: 0, appeal: 0, total: 0 };
  let complaint = 0, location = 0, appeal = 0;
  for (let i = 1; i < data.length; i++) {
    complaint += Number(data[i][5]) || 0;
    location  += Number(data[i][6]) || 0;
    appeal    += Number(data[i][7]) || 0;
  }
  return {
    users: data.length - 1,
    complaint, location, appeal,
    total: complaint + location + appeal
  };
}

// ─── TELEGRAM YORDAMCHILAR ────────────────────────────────────
function api(method, payload) {
  UrlFetchApp.fetch(BASE_URL + "/" + method, {
    method: "post",
    contentType: "application/json",
    payload: JSON.stringify(payload),
    muteHttpExceptions: true,
  });
}

function sendMsg(chatId, text, keyboard) {
  const p = { chat_id: chatId, text, parse_mode: "Markdown" };
  if (keyboard) p.reply_markup = JSON.stringify(keyboard);
  api("sendMessage", p);
}

function editMsg(chatId, msgId, text, keyboard) {
  const p = { chat_id: chatId, message_id: msgId, text, parse_mode: "Markdown" };
  if (keyboard) p.reply_markup = JSON.stringify(keyboard);
  api("editMessageText", p);
}

function sendPhotoMsg(chatId, fileId, caption) {
  api("sendPhoto", { chat_id: chatId, photo: fileId, caption, parse_mode: "Markdown" });
}

function answerCb(id) {
  api("answerCallbackQuery", { callback_query_id: id });
}

function removeKeyboard(chatId) {
  api("sendMessage", {
    chat_id: chatId,
    text: "...",
    reply_markup: JSON.stringify({ remove_keyboard: true }),
  });
  // kichik xabarni o'chirib yuborish mumkin emas, lekin keyboard ketadi
}

